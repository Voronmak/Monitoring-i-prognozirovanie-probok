<Window x:Class="Мониторинг_и_прогнозирование_пробок.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Мониторинг_и_прогнозирование_пробок"
        mc:Ignorable="d"
        Title="Мониторинг и прогнозирование пробок" Height="600" Width="950">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                 Text="Мониторинг и прогнозирование пробок" 
                 FontStyle="Normal"
                 FontSize="20"
                 FontWeight="Bold"
                 TextAlignment="Center"
                 Foreground="#FFFFFF"
                 Padding="15"
                 Margin="10"
                 Background="#8B2C2C"/>
        <TabControl Grid.Row="1">
            <TabItem Header="Историческая скорость"  Background="#8B2C2C">
                <Grid Margin ="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5" Background="#EBEBEB">
                        <ListBox x:Name="lstskrorost" Height="380" Margin="5" Background="#D9D9D9"/>
                        <Button x:Name="btnObnovi" Content="Обновить" Margin="5" Width="182" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5"  Background="#EBEBEB">
                        <Label Content="ID" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtid" Margin="5,0,5,10" Tag="ID" Background="#D9D9D9"/>
                        <Label Content="Дата" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtdate" Margin="5,0,5,10" Tag="Date" Background="#D9D9D9"/>
                        <Label Content="Средняя скорость" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtspeed" Margin="5,0,5,10" Tag="SrSpeed" Background="#D9D9D9"/>
                        <Label Content="Скорость медленного потока" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtspeedmedlp" Margin="5,0,5,10" Tag="SpeedMedlPotoka" Background="#D9D9D9"/>
                        <Label Content="Скорость быстрого потока" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtspeedbystrp" Margin="5,0,5,10" Tag="SpeedBystrPotoka" Background="#D9D9D9"/>
                        <Label Content="ID прогноза" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtIDPrognoza" Margin="5,0,5,10" Tag="IDPrognoza" Background="#D9D9D9"/>

                        <StackPanel Orientation="Horizontal" Margin="0,80,0,1" VerticalAlignment="Bottom">
                            <Button x:Name="BtnAdd" Content="Добавить"
                                    Background="#A3EFA6"
                                    VerticalAlignment="Bottom"
                                    Foreground="Black" Width="125" Margin="10,0,5,10">
                            </Button>
                            <Button x:Name="BtnDelete" Content="Удалить"
                                    Background="#BD8383"
                                    VerticalAlignment="Bottom"
                                    Foreground="Black" Width="125" Margin="25,0,5,10">
                            </Button>
                            <Button x:Name="BtnChange" Content="Редактировать"
                                    Background="#787FCE"
                                    VerticalAlignment="Bottom"
                                    Foreground="Black" Width="125" Margin="20,0,5,10">
                            </Button>
                        </StackPanel>
                    </StackPanel>
                    
                </Grid>
            </TabItem>

            <TabItem Header="Прогноз скорости"  Background="#8B2C2C">
                <Grid Margin ="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5" Background="#EBEBEB">
                        <ListBox x:Name="Prognozskrorost" Height="380" Margin="5" Background="#D9D9D9"/>
                        <Button x:Name="btnObnov" Content="Обновить" Margin="5" Width="182" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5"  Background="#EBEBEB">
                        <Label Content="ID" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtIDPr" Margin="5,0,5,10" Tag="ID" Background="#D9D9D9"/>
                        <Label Content="Время" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtTime" Margin="5,0,5,10" Tag="Date" Background="#D9D9D9"/>
                        <Label Content="Дата создания прогноза" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtDataSozd" Margin="5,0,5,10" Tag="SrSpeed" Background="#D9D9D9"/>
                        <Label Content="Скорость при прогнозе" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtspeedpriprognoz" Margin="5,0,5,10" Tag="SpeedMedlPotoka" Background="#D9D9D9"/>

                        <StackPanel Orientation="Horizontal" Margin="0,80,0,1" VerticalAlignment="Bottom">
                            <Button x:Name="BtnAdd1" Content="Добавить"
                        Background="#A3EFA6"
                        VerticalAlignment="Bottom"
                        Foreground="Black" Width="125" Margin="10,0,5,10">
                            </Button>
                            <Button x:Name="BtnDelete1" Content="Удалить"
                        Background="#BD8383"
                        VerticalAlignment="Bottom"
                        Foreground="Black" Width="125" Margin="25,0,5,10">
                            </Button>
                            <Button x:Name="BtnChange1" Content="Редактировать"
                        Background="#787FCE"
                        VerticalAlignment="Bottom"
                        Foreground="Black" Width="125" Margin="20,0,5,10">
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Тип дня" Background="#8B2C2C">
                <Grid Margin ="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5" Background="#EBEBEB">
                        <ListBox x:Name="TypeDay" Height="380" Margin="5" Background="#D9D9D9"/>
                        <Button x:Name="btnObnov1" Content="Обновить" Margin="5" Width="182" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5"  Background="#EBEBEB">
                        <Label Content="ID" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtIDType" Margin="5,0,5,10" Tag="ID" Background="#D9D9D9"/>
                        <Label Content="День недели" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtDay" Margin="5,0,5,10" Tag="Date" Background="#D9D9D9"/>
                        <Label Content="Праздник" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <CheckBox x:Name="txtPrazdnik" Margin="5,0,5,10" Tag="SrSpeed" Background="#D9D9D9"/>
                        <Label Content="Нагрузка" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtNagruzka" Margin="5,0,5,10" Tag="SpeedMedlPotoka" Background="#D9D9D9"/>
                        <Label Content="ID прогноза" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtIDprognoza" Margin="5,0,5,10" Tag="SpeedMedlPotoka" Background="#D9D9D9"/>

                        <StackPanel Orientation="Horizontal" Margin="0,80,0,1" VerticalAlignment="Bottom">
                            <Button x:Name="BtnAdd2" Content="Добавить"
                                    Background="#A3EFA6"
                                    VerticalAlignment="Bottom"
                                    Foreground="Black" Width="125" Margin="10,0,5,10">
                            </Button>
                            <Button x:Name="BtnDelete2" Content="Удалить"
                                    Background="#BD8383"
                                    VerticalAlignment="Bottom"
                                    Foreground="Black" Width="125" Margin="25,0,5,10">
                            </Button>
                            <Button x:Name="BtnChange2" Content="Редактировать"
                                    Background="#787FCE"
                                    VerticalAlignment="Bottom"
                                    Foreground="Black" Width="125" Margin="20,0,5,10">
                            </Button>
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </TabItem>

        </TabControl>

    </Grid>
</Window>

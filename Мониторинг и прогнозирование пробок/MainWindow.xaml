<Window x:Class="Мониторинг_и_прогнозирование_пробок.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Мониторинг_и_прогнозирование_пробок"
        mc:Ignorable="d"
        Title="Мониторинг и прогнозирование пробок" Height="610" Width="950">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Vertical">
            <TextBlock Grid.Row="0"
            Text="Мониторинг и прогнозирование пробок" 
            FontStyle="Normal"
            FontSize="20"
            FontWeight="Bold"
            TextAlignment="Center"
            Foreground="#FFFFFF"
            Padding="15"
            Margin="10"
            Background="#8B2C2C"/>
            <Image Source="/images/vecteezy_3d-model-icon-car-illustration_17339072.png" Width="35" Height="35" HorizontalAlignment="Right"
                   Margin="0,-10,10,0"/>
        </StackPanel>

        <TabControl Grid.Row="1" Name="TabControlMain">
            <TabItem Header="Историческая скорость"  Background="#8B2C2C" Height="22" Margin="-2,-0,-2,0" VerticalAlignment="Top" Name="TabItemHist">
                <Grid Margin ="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5" Background="#EBEBEB">
                        <DataGrid x:Name="lstskrorost" Height="380" Margin="5" Background="#D9D9D9" 
                                  AutoGenerateColumns="True" SelectionChanged="Lstskrorost_SelectionChanged"/>
                        <Button x:Name="btnObnovi" Content="Обновить" Margin="5" Width="182" HorizontalAlignment="Left" Click="btnObnovi_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5"  Background="#EBEBEB">
                        <Label Content="ID" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtid" Margin="5,0,5,10" Tag="ID" Background="#D9D9D9"/>
                        <Label Content="Дата" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtdate" Margin="5,0,5,10" Tag="Date" Background="#D9D9D9"/>
                        <Label Content="Средняя скорость" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtspeed" Margin="5,0,5,10" Tag="SrSpeed" Background="#D9D9D9"/>
                        <Label Content="Скорость медленного потока" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtspeedmedlp" Margin="5,0,5,10" Tag="SpeedMedlPotoka" Background="#D9D9D9"/>
                        <Label Content="Скорость быстрого потока" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtspeedbystrp" Margin="5,0,5,10" Tag="SpeedBystrPotoka" Background="#D9D9D9"/>
                        <Label Content="ID прогноза" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtIDPrognoza" Margin="5,0,5,10" Tag="IDPrognoza" Background="#D9D9D9"/>

                        <StackPanel Orientation="Horizontal" Margin="0,81,0,1" VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal"
                                        Background="#A3EFA6"
                                        Margin="10,0,5,10" 
                                        Width="140" 
                                        MouseLeftButtonDown="IstSkorostAdd_MouseLeftButtonDown">
                                <Image Source="C:\Users\163149\Source\Repos\Monitoring-i-prognozirovanie-probok\Мониторинг и прогнозирование пробок\images\add.png" Width="15" Height="15" RenderTransformOrigin="8.622,-1.61"
                                       />
                                <Label Content="Добавить"
                                         Margin="20,-3,0,-3"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" MouseLeftButtonDown="IstSkorostDel_MouseLeftButtonDown"
                                         Background="#BD8383"
                                         Margin="10,0,5,10" Width="140">
                                <Image Source="C:\Users\163149\Source\Repos\Monitoring-i-prognozirovanie-probok\Мониторинг и прогнозирование пробок\images\trash.png" Width="15" Height="15"/>
                                <Label Content="Удалить"
                                        Margin="28,-3,0,-3"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" MouseLeftButtonDown="IstSkorostEdit_MouseLeftButtonDown"
                                        Background="#787FCE"
                                        Margin="10,0,5,10" Width="140">
                                <Image Source="C:\Users\163149\Source\Repos\Monitoring-i-prognozirovanie-probok\Мониторинг и прогнозирование пробок\images\agreement.png" Width="15" Height="15"/>
                                <Label Content="Редактировать"
                                        Margin="10,-3,0,-3"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </TabItem>

            <TabItem Header="Прогноз скорости"  Background="#8B2C2C" Name="TabItemPrognoz">
                <Grid Margin ="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5" Background="#EBEBEB">
                        <DataGrid x:Name="Prognozskrorost" Height="380" Margin="5" Background="#D9D9D9"
                                  AutoGenerateColumns="True" SelectionChanged="Prognozskrorost_SelectionChanged"/>
                        <Button x:Name="btnObnov" Content="Обновить" Margin="5" Width="182" HorizontalAlignment="Left" Click="btnObnovi_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5"  Background="#EBEBEB">
                        <Label Content="ID" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtIDPr" Margin="5,0,5,10" Tag="ID" Background="#D9D9D9"/>
                        <Label Content="Время" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtTime" Margin="5,0,5,10" Tag="Date" Background="#D9D9D9"/>
                        <Label Content="Дата создания прогноза" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtDataSozd" Margin="5,0,5,10" Tag="SrSpeed" Background="#D9D9D9"/>
                        <Label Content="Скорость при прогнозе" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtspeedpriprognoz" Margin="5,0,5,10" Tag="SpeedMedlPotoka" Background="#D9D9D9"/>

                        <StackPanel Orientation="Horizontal" Margin="0,185,0,1" VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal"
                                Background="#A3EFA6"
                                Margin="10,0,5,10" 
                                Width="140" MouseLeftButtonDown="PrognozSkorostAdd_MouseLeftButtonDown">
                                <Image Source="C:\Users\163149\Source\Repos\Monitoring-i-prognozirovanie-probok\Мониторинг и прогнозирование пробок\images\add.png" Width="15" Height="15" RenderTransformOrigin="8.622,-1.61"/>
                                <Label Content="Добавить"
                                    Margin="20,-3,0,-3"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" MouseLeftButtonDown="IstSkorostDel_MouseLeftButtonDown"
                                Background="#BD8383"
                                Margin="10,0,5,10" Width="140">
                                <Image Source="C:\Users\163149\Source\Repos\Monitoring-i-prognozirovanie-probok\Мониторинг и прогнозирование пробок\images\trash.png" Width="15" Height="15"/>
                                <Label Content="Удалить"
                                     Margin="28,-3,0,-3"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" MouseLeftButtonDown="PrognozSkorostEdit_MouseLeftButtonDown"
                                Background="#787FCE"
                                Margin="10,0,5,10" Width="140">
                                <Image Source="C:\Users\163149\Source\Repos\Monitoring-i-prognozirovanie-probok\Мониторинг и прогнозирование пробок\images\agreement.png" Width="15" Height="15"/>
                                <Label Content="Редактировать"
                                     Margin="10,-3,0,-3"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Тип дня" Background="#8B2C2C" Name="TabItemType">
                <Grid Margin ="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5" Background="#EBEBEB">
                        <DataGrid x:Name="TypeDay" Height="380" Margin="5" Background="#D9D9D9"
                                  AutoGenerateColumns="True" SelectionChanged="TypeDay_SelectionChanged"/>
                        <Button x:Name="btnObnov1" Content="Обновить" Margin="5" Width="182" HorizontalAlignment="Left" Click="btnObnovi_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5"  Background="#EBEBEB">
                        <Label Content="ID" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtIDType" Margin="5,0,5,10" Tag="ID" Background="#D9D9D9"/>
                        <Label Content="День недели" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtDay" Margin="5,0,5,10" Tag="Date" Background="#D9D9D9"/>
                        <Label Content="Праздник" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <CheckBox x:Name="txtPrazdnik" Margin="5,0,5,10" Tag="SrSpeed" Background="#D9D9D9"/>
                        <Label Content="Нагрузка" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtNagruzka" Margin="5,0,5,10" Tag="SpeedMedlPotoka" Background="#D9D9D9"/>
                        <Label Content="ID прогноза" FontWeight="Normal" FontSize="14" Margin="0,0,0,-5"/>
                        <TextBox x:Name="txtIDprognoza" Margin="5,0,5,10" Tag="SpeedMedlPotoka" Background="#D9D9D9"/>

                        <StackPanel Orientation="Horizontal" Margin="0,136,0,1" VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal"
                                        Background="#A3EFA6"
                                        Margin="10,0,5,10" 
                                        Width="140" MouseLeftButtonDown="TypeDayAdd_MouseLeftButtonDown">
                                <Image Source="C:\Users\163149\Source\Repos\Monitoring-i-prognozirovanie-probok\Мониторинг и прогнозирование пробок\images\add.png" Width="15" Height="15" RenderTransformOrigin="8.622,-1.61"   />
                                <Label Content="Добавить"
                                        Margin="20,-3,0,-3"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" MouseLeftButtonDown="TypeDayDel_MouseLeftButtonDown"
                                        Background="#BD8383"
                                        Margin="10,0,5,10" Width="140">
                                <Image Source="C:\Users\163149\Source\Repos\Monitoring-i-prognozirovanie-probok\Мониторинг и прогнозирование пробок\images\trash.png" Width="15" Height="15"/>
                                <Label Content="Удалить"
                                        Margin="28,-3,0,-3"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" MouseLeftButtonDown="TypeDayEdit_MouseLeftButtonDown"
                                        Background="#787FCE"
                                        Margin="10,0,5,10" Width="140">
                                <Image Source="C:\Users\163149\Source\Repos\Monitoring-i-prognozirovanie-probok\Мониторинг и прогнозирование пробок\images\agreement.png" Width="15" Height="15"/>
                                <Label Content="Редактировать"
                                        Margin="10,-3,0,-3"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Мониторинг пробок" Background="#8B2C2C" Name="TabItemMonitoring">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#EBEBEB" Margin="5" Padding="10" CornerRadius="5">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,10">
                                <Button x:Name="BtnByDay" Content="Средняя скорость по дням недели"
                            Width="220" Height="25" Margin="0,0,10,0"
                            Background="#8B2C2C" Foreground="White"
                            Click="BtnByDay_Click"/>

                                <Button x:Name="BtnWorst" Content="Топ пробочных дней"
                            Width="150" Height="25" Margin="0,0,10,0"
                            Background="#8B2C2C" Foreground="White"
                            Click="BtnWorst_Click"/>

                                <Button x:Name="StatistikButton" Content="Обновить"
                            Width="100" Height="25"
                            Background="#8B2C2C" Foreground="White"
                            Click="StatistikButton_Click"/>
                            </WrapPanel>

                            <WrapPanel>
                                <Button x:Name="BtnSelectAll" Content="SELECT * (все данные)"
                            Width="180" Height="25" Margin="0,0,10,0"
                            Background="#8B2C2C" Foreground="White"
                            Click="BtnSelectAll_Click"/>

                                <Button x:Name="BtnWhereSpeed" Content="WHERE (скорость > 50)"
                            Width="180" Height="25" Margin="-5,0,10,0"
                            Background="#8B2C2C"  Foreground="White"
                            Click="BtnWhereSpeed_Click"/>

                                <Button x:Name="BtnOrderBySpeed" Content="ORDER BY (скорость от низкого к высокому)"
                            Width="250" Height="25" Margin="-5,0,10,0"
                            Background="#8B2C2C" Foreground="White"
                            Click="BtnOrderBySpeed_Click"/>

                                <Button x:Name="BtnOrderBySpeedDesc" Content="ORDER BY (скорость от высокого к низкому)"
                            Width="250" Height="25" Margin="-5,0,10,0"
                            Background="#8B2C2C" Foreground="White"
                            Click="BtnOrderBySpeedDesc_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="Type" Margin="5" 
                  Background="#D9D9D9" AutoGenerateColumns="True"
                  CanUserAddRows="False" IsReadOnly="True"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
